<?xml version="1.0" encoding="utf-8"?>
<schemalist>
  <schema path="/com/adrienplazas/Metronome/" id="@app-id@" gettext-domain="@gettext-package@">
    <key name="window-width" type="i">
      <default>-1</default>
      <summary>Default window width</summary>
      <description>Default window width</description>
    </key>
    <key name="window-height" type="i">
      <default>-1</default>
      <summary>Default window height</summary>
      <description>Default window height</description>
    </key>
    <key name="is-maximized" type="b">
      <default>false</default>
      <summary>Default window maximized behaviour</summary>
      <description></description>
    </key>
    <key name="beats-per-bar" type="u">
      <range min="1" max="99"/>
      <default>4</default>
      <summary>Default beats per bar</summary>
      <description>Default beats per bar</description>
    </key>
    <key name="beats-per-minute" type="u">
      <range min="20" max="260"/>
      <default>100</default>
      <summary>Default beats per minute</summary>
      <description>Default beats per minute</description>
    </key>
    <key name="volume" type="d">
      <range min="0.0" max="1.0"/>
      <default>1.0</default>
      <summary>Click volume</summary>
      <description>Volume of the metronome click (0.0 = silent, 1.0 = full volume)</description>
    </key>
    <key name="active-theme" type="s">
      <default>'Monokai'</default>
      <summary>Active color theme</summary>
      <description>Name of the active color theme. Empty string uses default Adwaita colors.</description>
    </key>
    <key name="tempo-ramp-enabled" type="b">
      <default>false</default>
      <summary>Enable gradual tempo increase</summary>
      <description>When enabled, BPM increases automatically during playback</description>
    </key>
    <key name="tempo-ramp-increment" type="u">
      <range min="1" max="50"/>
      <default>5</default>
      <summary>Tempo ramp BPM increment</summary>
      <description>BPM increase per interval</description>
    </key>
    <key name="tempo-ramp-bars" type="u">
      <range min="1" max="32"/>
      <default>4</default>
      <summary>Tempo ramp bar interval</summary>
      <description>Number of bars between each BPM increase</description>
    </key>
    <key name="tempo-ramp-target" type="u">
      <range min="20" max="260"/>
      <default>260</default>
      <summary>Tempo ramp target BPM</summary>
      <description>Maximum BPM the ramp will reach</description>
    </key>
    <key name="background-image-path" type="s">
      <default>''</default>
      <summary>Background image path</summary>
      <description>Absolute path to a background image file. Empty string means no background.</description>
    </key>
    <key name="background-opacity" type="d">
      <range min="0.0" max="1.0"/>
      <default>0.15</default>
      <summary>Background image opacity</summary>
      <description>Opacity of the background image (0.0 = invisible, 1.0 = fully opaque)</description>
    </key>
    <key name="background-style" type="s">
      <default>'cover'</default>
      <summary>Background image style</summary>
      <description>How the background image is displayed: cover, contain, fill, tile</description>
    </key>
    <key name="scale-root" type="u">
      <range min="0" max="11"/>
      <default>0</default>
      <summary>Scale root note index</summary>
      <description>Index into the chromatic note list (0=C, 1=C#, ... 11=B)</description>
    </key>
    <key name="scale-family" type="u">
      <range min="0" max="4"/>
      <default>0</default>
      <summary>Scale family index</summary>
      <description>Index of the scale family (0=Major, 1=Melodic Minor, 2=Harmonic Minor, 3=Messiaen, 4=Other)</description>
    </key>
    <key name="scale-mode" type="u">
      <range min="0" max="9"/>
      <default>0</default>
      <summary>Scale mode index</summary>
      <description>Index of the mode within the selected family</description>
    </key>
  </schema>
</schemalist>
