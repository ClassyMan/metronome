<?xml version="1.0" encoding="utf-8"?>
<schemalist>
  <schema path="/com/adrienplazas/Metronome/" id="@app-id@" gettext-domain="@gettext-package@">
    <key name="window-width" type="i">
      <default>-1</default>
      <summary>Default window width</summary>
      <description>Default window width</description>
    </key>
    <key name="window-height" type="i">
      <default>-1</default>
      <summary>Default window height</summary>
      <description>Default window height</description>
    </key>
    <key name="is-maximized" type="b">
      <default>false</default>
      <summary>Default window maximized behaviour</summary>
      <description></description>
    </key>
    <key name="beats-per-bar" type="u">
      <range min="1" max="9"/>
      <default>4</default>
      <summary>Default beats per bar</summary>
      <description>Default beats per bar</description>
    </key>
    <key name="beats-per-minute" type="u">
      <range min="20" max="260"/>
      <default>100</default>
      <summary>Default beats per minute</summary>
      <description>Default beats per minute</description>
    </key>
    <key name="active-theme" type="s">
      <default>'Monokai'</default>
      <summary>Active color theme</summary>
      <description>Name of the active color theme. Empty string uses default Adwaita colors.</description>
    </key>
    <key name="tempo-ramp-enabled" type="b">
      <default>false</default>
      <summary>Enable gradual tempo increase</summary>
      <description>When enabled, BPM increases automatically during playback</description>
    </key>
    <key name="tempo-ramp-increment" type="u">
      <range min="1" max="50"/>
      <default>5</default>
      <summary>Tempo ramp BPM increment</summary>
      <description>BPM increase per interval</description>
    </key>
    <key name="tempo-ramp-bars" type="u">
      <range min="1" max="32"/>
      <default>4</default>
      <summary>Tempo ramp bar interval</summary>
      <description>Number of bars between each BPM increase</description>
    </key>
    <key name="tempo-ramp-target" type="u">
      <range min="20" max="260"/>
      <default>260</default>
      <summary>Tempo ramp target BPM</summary>
      <description>Maximum BPM the ramp will reach</description>
    </key>
  </schema>
</schemalist>
