<interface>
  <menu id="primary_menu">
    <section>
      <item>
        <attribute name="label" translatable="yes">_Keyboard Shortcuts</attribute>
        <attribute name="action">win.show-help-overlay</attribute>
      </item>
      <item>
        <attribute name="label" translatable="yes">_About Metronome</attribute>
        <attribute name="action">app.about</attribute>
      </item>
    </section>
  </menu>
  <template class="MtrApplicationWindow" parent="AdwApplicationWindow">
    <property name="default-width">600</property>
    <style>
      <class name="application"/>
    </style>
    <child>
      <object class="GtkWindowHandle">
        <child>
          <object class="GtkCenterBox">
            <property name="orientation">vertical</property>
            <child type="start">
              <object class="GtkHeaderBar" id="header">
                <child type="title">
                  <object class="GtkBox">
                    <property name="visible">False</property>
                  </object>
                </child>
                <style>
                  <class name="flat"/>
                </style>
              </object>
            </child>
            <child type="center">
              <object class="GtkBox">
                <property name="orientation">vertical</property>
                <child>
                  <object class="GtkBox" id="time_signature">
                    <property name="halign">center</property>
                    <style>
                      <class name="time-signature"/>
                    </style>
                    <child>
                      <object class="GtkToggleButton" id="time_signature_2_4_button">
                        <signal name="notify::active" handler="on_time_signature_2_4_button_active" swapped="true" />
                        <property name="group">time_signature_4_4_button</property>
                        <property name="tooltip-text">2/4 Time</property>
                        <property name="halign">center</property>
                        <property name="valign">center</property>
                        <style>
                          <class name="circular"/>
                          <class name="large"/>
                          <class name="text-button"/>
                        </style>
                        <child>
                          <object class="GtkLabel">
                            <property name="justify">center</property>
                            <property name="label" translatable="yes">2
4</property>
                          </object>
                        </child>
                      </object>
                    </child>
                    <child>
                      <object class="GtkToggleButton" id="time_signature_3_4_button">
                        <signal name="notify::active" handler="on_time_signature_3_4_button_active" swapped="true" />
                        <property name="tooltip-text">3/4 Time</property>
                        <property name="group">time_signature_4_4_button</property>
                        <property name="halign">center</property>
                        <property name="valign">center</property>
                        <style>
                          <class name="circular"/>
                          <class name="large"/>
                          <class name="text-button"/>
                        </style>
                        <child>
                          <object class="GtkLabel">
                            <property name="justify">center</property>
                            <property name="label" translatable="yes">3
4</property>
                          </object>
                        </child>
                      </object>
                    </child>
                    <child>
                      <object class="GtkToggleButton" id="time_signature_4_4_button">
                        <signal name="notify::active" handler="on_time_signature_4_4_button_active" swapped="true" />
                        <property name="tooltip-text">4/4 Time</property>
                        <property name="active">True</property>
                        <property name="halign">center</property>
                        <property name="valign">center</property>
                        <style>
                          <class name="circular"/>
                          <class name="large"/>
                          <class name="text-button"/>
                        </style>
                        <child>
                          <object class="GtkLabel">
                            <property name="justify">center</property>
                            <property name="label" translatable="yes">4
4</property>
                          </object>
                        </child>
                      </object>
                    </child>
                    <child>
                      <object class="GtkToggleButton" id="time_signature_6_8_button">
                        <signal name="notify::active" handler="on_time_signature_6_8_button_active" swapped="true" />
                        <property name="group">time_signature_4_4_button</property>
                        <property name="tooltip-text">6/8 Time</property>
                        <property name="halign">center</property>
                        <property name="valign">center</property>
                        <style>
                          <class name="circular"/>
                          <class name="large"/>
                          <class name="text-button"/>
                        </style>
                        <child>
                          <object class="GtkLabel">
                            <property name="justify">center</property>
                            <property name="label" translatable="yes">6
8</property>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="AdwClamp">
                    <property name="tightening-threshold">360</property>
                    <property name="maximum-size">480</property>
                    <child>
                      <object class="GtkBox">
                        <property name="orientation">vertical</property>
                        <style>
                          <class name="display"/>
                          <class name="card"/>
                        </style>
                        <child>
                          <object class="GtkBox">
                            <property name="halign">center</property>
                            <child>
                              <object class="GtkLabel">
                                <property name="label" bind-source="MtrApplicationWindow" bind-property="beats-per-minute" bind-flags="sync-create">BPM</property>
                                <property name="width-chars">3</property>
                                <style>
                                  <class name="bpm"/>
                                </style>
                              </object>
                            </child>
                            <child>
                              <object class="GtkBox">
                                <property name="orientation">vertical</property>
                                <property name="valign">center</property>
                                <style>
                                  <class name="bpm"/>
                                </style>
                                <child>
                                  <object class="GtkButton">
                                    <property name="action_name">win.increase-bpm</property>
                                    <property name="halign">center</property>
                                    <property name="icon-name">value-increase-symbolic</property>
                                    <property name="valign">center</property>
                                    <property name="tooltip-text" translatable="yes">Increase BPM</property>
                                    <style>
                                      <class name="circular"/>
                                    </style>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkButton">
                                    <property name="action_name">win.decrease-bpm</property>
                                    <property name="halign">center</property>
                                    <property name="icon-name">value-decrease-symbolic</property>
                                    <property name="valign">center</property>
                                    <property name="tooltip-text" translatable="yes">Decrease BPM</property>
                                    <style>
                                      <class name="circular"/>
                                    </style>
                                  </object>
                                </child>
                              </object>
                            </child>
                          </object>
                        </child>
                        <child>
                          <object class="GtkScale" id="bpm_scale">
                            <property name="adjustment">bpm_adjustment</property>
                            <property name="digits">0</property>
                            <property name="margin-bottom">8</property>
                            <property name="margin-start">8</property>
                            <property name="margin-end">8</property>
                            <marks>
                              <mark value="20" position="bottom">20</mark>
                              <mark value="80" position="bottom">80</mark>
                              <mark value="140" position="bottom">140</mark>
                              <mark value="200" position="bottom">200</mark>
                              <mark value="260" position="bottom">260</mark>
                            </marks>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="GtkBox" id="controls">
                    <property name="halign">center</property>
                    <style>
                      <class name="controls"/>
                    </style>
                    <child>
                      <object class="GtkButton" id="tap_button">
                        <property name="action_name">win.tap</property>
                        <property name="halign">center</property>
                        <property name="label" translatable="yes">TAP</property>
                        <property name="valign">center</property>
                        <style>
                          <class name="circular"/>
                          <class name="large"/>
                        </style>
                      </object>
                    </child>
                    <child>
                      <object class="MtrTimerButton" id="timer_button">
                        <property name="beats-per-bar" bind-source="MtrApplicationWindow" bind-property="beats-per-bar" bind-flags="sync-create"/>
                        <property name="beats-per-minute" bind-source="MtrApplicationWindow" bind-property="beats-per-minute" bind-flags="sync-create"/>
                      </object>
                    </child>
                    <child type="end">
                      <object class="GtkMenuButton" id="appmenu_button">
                        <property name="primary">true</property>
                        <property name="tooltip-text" translatable="yes">Main Menu</property>
                        <property name="halign">center</property>
                        <property name="icon-name">open-menu-symbolic</property>
                        <property name="menu-model">primary_menu</property>
                        <property name="valign">center</property>
                        <style>
                          <class name="circular"/>
                          <class name="large"/>
                        </style>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </child>
            <child type="end">
              <object class="GtkBox" id="footer"/>
            </child>
          </object>
        </child>
      </object>
    </child>
  </template>
  <object class="GtkAdjustment" id="bpm_adjustment">
    <property name="lower">20</property>
    <property name="upper">260</property>
    <property name="page-increment">10</property>
    <property name="step-increment">1</property>
    <property name="value" bind-source="MtrApplicationWindow" bind-property="beats-per-minute" bind-flags="bidirectional">100</property>
  </object>
  <object class="GtkSizeGroup">
    <property name="mode">vertical</property>
    <widgets>
      <widget name="time_signature"/>
      <widget name="controls"/>
    </widgets>
  </object>
  <object class="GtkSizeGroup">
    <property name="mode">vertical</property>
    <widgets>
      <widget name="header"/>
      <widget name="footer"/>
    </widgets>
  </object>
  <object class="MtrTimer" id="timer">
    <property name="active" bind-source="timer_button" bind-property="active" bind-flags="sync-create"/>
    <property name="beats-per-bar" bind-source="MtrApplicationWindow" bind-property="beats-per-bar" bind-flags="sync-create"/>
    <property name="beats-per-minute" bind-source="MtrApplicationWindow" bind-property="beats-per-minute" bind-flags="sync-create"/>
    <signal name="beat" handler="on_beat" swapped="true" />
  </object>
</interface>
