<?xml version="1.0" encoding="UTF-8"?>
<!-- Adrien Plazas 2019 <kekun.plazas@laposte.net> -->
<component type="desktop-application">
  <id>@app-id@</id>
  <metadata_license>CC0</metadata_license>
  <project_license>GPL-3.0+</project_license>
  <name>Metronome</name>
  <summary>Practice music with a regular tempo</summary>
  <description>
    <p>Metronome beats the rhythm for you, you simply need to tell it the required time signature and beats per minutes.</p>
    <p>You can also tap to let the application guess the required beats per minute.</p>
  </description>
  <screenshots>
    <screenshot type="default">
      <image>https://gitlab.gnome.org/aplazas/metronome/raw/master/data/resources/screenshots/screenshot1.png</image>
      <caption>Main window</caption>
    </screenshot>
    <screenshot type="default">
      <image>https://gitlab.gnome.org/aplazas/metronome/raw/master/data/resources/screenshots/screenshot2.png</image>
      <caption>Main window, narrow and running</caption>
    </screenshot>
  </screenshots>
  <url type="homepage">https://gitlab.gnome.org/aplazas/metronome</url>
  <url type="bugtracker">https://gitlab.gnome.org/aplazas/metronome/issues</url>
  <url type="donation">https://liberapay.com/adrienplazas</url>
  <content_rating type="oars-1.0" />
  <releases>
    <release version="0.0.1" date="2021-05-06" />
  </releases>
  <kudos>
    <kudo>HighContrast</kudo>
    <kudo>HiDpiIcon</kudo>
    <kudo>ModernToolkit</kudo>
  </kudos>
  <developer_name>Adrien Plazas</developer_name>
  <update_contact>kekun.plazas@laposte.net</update_contact>
  <translation type="gettext">@gettext-package@</translation>
  <launchable type="desktop-id">@app-id@.desktop</launchable>
  <custom>
    <value key="Purism::form_factor">workstation</value>
    <value key="Purism::form_factor">mobile</value>
  </custom>
</component>
